{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with a specific role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "ADMIN", "DELIVERY", "SUPPLIER"] },
        "isDisabled": { "type": "boolean" }
      },
      "required": ["uid", "email", "role"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "A record of a system action for security auditing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string" },
        "actorId": { "type": "string" },
        "actorName": { "type": "string" },
        "action": { "type": "string" },
        "targetId": { "type": "string" },
        "details": { "type": "string" }
      },
      "required": ["id", "timestamp", "actorId", "action"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A ledger entry for a transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string", "format": "email" },
        "issueDate": { "type": "string" },
        "dueDate": { "type": "string" },
        "status": { "type": "string", "enum": ["Paid", "Pending", "Draft", "Overdue", "Out for Delivery", "Delivered"] },
        "items": { "type": "array" },
        "taxRate": { "type": "number" },
        "discount": { "type": "number" },
        "notes": { "type": "string" },
        "deliveryPerson": { "type": "string" },
        "deliveryNote": { "type": "string" },
        "deliveryNotes": { "type": "string" },
        "supplierNote": { "type": "string" },
        "spreadsheetId": { "type": "string" },
        "supplierPhotoUrl": { "type": "string" },
        "deliveryPhotoUrl": { "type": "string" }
      },
      "required": ["id", "clientName", "status", "items"]
    },
    "Client": {
      "title": "Client",
      "description": "Contact details and metadata for a business client.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "email", "createdAt"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Contact details and metadata for a supply partner.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "email", "createdAt"]
    },
    "DeliveryPerson": {
      "title": "DeliveryPerson",
      "description": "Contact details and metadata for a delivery scout.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "vehicleId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "email", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Collection of all invoices."
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Historical client database."
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Historical supplier database."
    },
    "/delivery_partners/{partnerId}": {
      "schema": "DeliveryPerson",
      "description": "Historical delivery partner database."
    },
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "System audit trail."
    }
  }
}
