rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActive() {
      return isSignedIn() && userExists() && (!('isDisabled' in getUserData()) || getUserData().isDisabled == false);
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        (isActive() && getUserData().role == 'super_admin') ||
        request.auth.token.email in ['liliprovisions@gmail.com', 'jamenya1988@gmail.com', 'skigo5917@gmail.com', 'gabriel.mugi66@gmail.com']
      );
    }

    function isAdmin() {
      return isSuperAdmin() || (isActive() && getUserData().role == 'admin');
    }

    function isAuthorized() {
      return isAdmin() || (isActive() && (getUserData().isAuthorized == true || getUserData().role in ['delivery', 'supplier']));
    }

    function isValidClient(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 256 &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt is string && data.createdAt.size() <= 128;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      allow create: if (isSignedIn() && request.auth.uid == userId && 
                    (!('role' in request.resource.data) || request.resource.data.role == 'delivery')) ||
                    isSuperAdmin();
      
      allow update: if isSignedIn() && (
        isSuperAdmin() || 
        (request.auth.uid == userId && 
         request.resource.data.role == resource.data.role && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAuthorized', 'isDisabled']))
      );
      
      allow delete: if isSuperAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isAuthorized();
      allow write: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isAuthorized();
      allow create: if isAdmin() && isValidClient(request.resource.data);
      allow update: if isAdmin() && isValidClient(request.resource.data);
      allow delete: if isAdmin();
    }

    match /suppliers/{supplierId} {
      allow read: if isAuthorized();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /delivery_partners/{partnerId} {
      allow read: if isAuthorized();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isSuperAdmin();
      // Writing to logs should be done during operations. 
      // For security, we allow any admin to append logs.
      allow create: if isAdmin();
    }
  }
}
